# ==========================================
# CẤU HÌNH HỆ THỐNG CHUNG (GLOBAL)
# ==========================================
NODE_ENV=development
LOG_LEVEL=debug
APP_NAME=SpaSaasPlatform

# URL Frontend (dùng cho CORS)
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://spa-saas.com

# ==========================================
# CẤU HÌNH DATABASE & CACHE
# ==========================================
DATABASE_URL=postgresql://user:password@localhost:5432/spa_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_TIMEOUT=30

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB_INDEX=0
REDIS_TTL=3600

# ==========================================
# CẤU HÌNH JWT & BẢO MẬT
# ==========================================
# Tạo key mạnh: openssl rand -base64 32
JWT_SECRET=your_super_long_and_secret_key_change_me
JWT_EXPIRATION=24h
# Salt rounds cho bcrypt
BCRYPT_SALT_ROUNDS=10

# ==========================================
# CẤU HÌNH CÁC MICROSERVICES (PORTS)
# ==========================================
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
BOOKING_SERVICE_PORT=3003
POS_SERVICE_PORT=3004
INVENTORY_SERVICE_PORT=3005
CRM_SERVICE_PORT=3006
AI_GATEWAY_PORT=3010
ANALYTICS_SERVICE_PORT=3013
ADMIN_SERVICE_PORT=3015

# ==========================================
# CẤU HÌNH AI LAYER
# ==========================================
GEMINI_API_KEY=your_gemini_key
OPENAI_API_KEY=your_openai_key
CLAUDE_API_KEY=your_claude_key
DEEPSEEK_API_KEY=your_deepseek_key
DEFAULT_AI_PROVIDER=gemini
AI_TIMEOUT=30000

# ==========================================
# CẤU HÌNH EMAIL SERVICE
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@spa-saas.com

# ==========================================
# CẤU HÌNH FILE STORAGE (S3/MinIO)
# ==========================================
STORAGE_TYPE=s3
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=spa-assets
S3_REGION=us-east-1
MAX_FILE_SIZE=10485760