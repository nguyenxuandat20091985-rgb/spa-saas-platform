# ==========================================
# CẤU HÌNH HỆ THỐNG CHUNG (GLOBAL)
# ==========================================
NODE_ENV=development
LOG_LEVEL=debug
APP_NAME=SpaSaasPlatform

# URL Frontend (dùng cho CORS)
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://spa-saas.com

# ==========================================
# CẤU HÌNH DATABASE & CACHE
# ==========================================
DATABASE_URL=postgresql://user:password@localhost:5432/spa_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_TIMEOUT=30

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB_INDEX=0
REDIS_TTL=3600

# ==========================================
# CẤU HÌNH JWT & BẢO MẬT
# ==========================================
# Tạo key mạnh: openssl rand -base64 32
JWT_SECRET=your_super_long_and_secret_key_change_me
JWT_EXPIRATION=24h
# Salt rounds cho bcrypt
BCRYPT_SALT_ROUNDS=10

# ==========================================
# CẤU HÌNH CÁC MICROSERVICES (PORTS)
# ==========================================
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
BOOKING_SERVICE_PORT=3003
POS_SERVICE_PORT=3004
INVENTORY_SERVICE_PORT=3005
CRM_SERVICE_PORT=3006
NOTIFICATION_SERVICE_PORT=3007
BILLING_SERVICE_PORT=3008
MEMBERSHIP_SERVICE_PORT=3009
AI_GATEWAY_PORT=3010
ANALYTICS_SERVICE_PORT=3013
MEDIA_SERVICE_PORT=3014
ADMIN_SERVICE_PORT=3015

# ==========================================
# CẤU HÌNH AI LAYER
# ==========================================
GEMINI_API_KEY=your_gemini_key
OPENAI_API_KEY=your_openai_key
CLAUDE_API_KEY=your_claude_key
DEEPSEEK_API_KEY=your_deepseek_key
DEFAULT_AI_PROVIDER=gemini
AI_TIMEOUT=30000

# ==========================================
# CẤU HÌNH EMAIL SERVICE
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@spa-saas.com

# ==========================================
# CẤU HÌNH SMS SERVICE
# ==========================================
SMS_PROVIDER=twilio
SMS_ACCOUNT_SID=your_twilio_account_sid
SMS_AUTH_TOKEN=your_twilio_auth_token
SMS_FROM=+1234567890

# ==========================================
# CẤU HÌNH ZALO OA
# ==========================================
ZALO_ACCESS_TOKEN=your_zalo_access_token
ZALO_OA_ID=your_zalo_oa_id

# ==========================================
# CẤU HÌNH FIREBASE CLOUD MESSAGING (PUSH)
# ==========================================
FIREBASE_SERVER_KEY=your_firebase_server_key

# ==========================================
# CẤU HÌNH FILE STORAGE (S3/MinIO)
# ==========================================
STORAGE_TYPE=s3
S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=spa-assets
S3_REGION=us-east-1
MAX_FILE_SIZE=10485760

# ==========================================
# CẤU HÌNH PAYMENT GATEWAY
# ==========================================
# VNPay
VNPAY_MERCHANT_ID=your_vnpay_merchant_id
VNPAY_SECRET_KEY=your_vnpay_secret_key
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay-return

# MoMo
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_RETURN_URL=http://localhost:3000/payment/momo-return

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ==========================================
# CẤU HÌNH VECTOR DB (Qdrant)
# ==========================================
VECTOR_DB_PROVIDER=qdrant
VECTOR_DB_HOST=qdrant
VECTOR_DB_PORT=6333
VECTOR_DB_API_KEY=your_qdrant_api_key
VECTOR_DB_COLLECTION=spa-knowledge

# ==========================================
# CẤU HÌNH EMBEDDING
# ==========================================
AI_EMBEDDING_BATCH_SIZE=100
AI_EMBEDDING_MAX_RETRIES=3
AI_EMBEDDING_RETRY_DELAY=1000